      "text_variants": [
        {
          "conditions": { "requires_flag": "found_promise_key" },
          "text": "Remember what has carried you — the Cross that took your burden, and the Promise that unlocked the giant's cell. This water cannot take what those gave you.",
          "text_zh": "记起是什么托住了你——那除去你重担的十字架，那打开巨人牢门的应许。这河水，夺不走它们给你的。"
        }
      ],
      "choices": [
        {
          "id": "cross",
          "text": "Remember the Cross.",
          "text_zh": "记起十字架。",
          "effects": { "faith": 15, "shame": -10, "fear": -10 },
          "flags": { "river_memory_recalled": true },
          "next": "end"
        },
        {
