  "toast.child_mode": {
    "en": "Children's Journey — a gentle road. Take your time.",
    "zh": "孩童之旅——一条温柔的路。慢慢来。"
  },
  "end.title": {
    "en": "You have crossed the river and entered in.",
    "zh": "你已渡过那河，进入其中。"
  },
  "end.l1": {
    "en": "From first awakening to final welcome,",
    "zh": "从最初的醒觉，到最终的迎接，"
  },
  "end.l2": {
    "en": "grace has carried the pilgrim home.",
    "zh": "恩典已把朝圣者带回家。"
  },
  "end.l3": {
    "en": "The burden is gone. The City is before you.",
    "zh": "重担已不在。圣城就在你眼前。"
  },
  "collapse.title": {
    "en": "You have sunk down under the weight.",
    "zh": "你在重压之下沉了下去。"
  },
  "collapse.l1": {
    "en": "Trying harder cannot raise a heart that needs mercy.",
    "zh": "更用力，也举不起一颗需要怜悯的心。"
  },
  "collapse.l2": {
    "en": "But the way back was never closed. Tell the truth, and receive help:",
    "zh": "但归途从未关闭。说出真相，接受帮助："
  },
  "toast.lifted": {
    "en": "You are lifted by grace, not by self-rescue. Walk on.",
    "zh": "扶你起来的是恩典，不是自救。继续走吧。"
  },
  "repent.afraid": {
    "en": "\"I was afraid, and I obeyed fear as if it were truth.\"",
    "zh": "“我惧怕了，便顺从恐惧，仿佛它就是真理。”"
  },
  "repent.pride": {
    "en": "\"I trusted myself, and called refusal to receive help strength.\"",
    "zh": "“我倚靠自己，把拒绝受助唤作刚强。”"
  },
  "repent.despair": {
    "en": "\"I believed despair when it said mercy was finished with me.\"",
    "zh": "“当绝望说怜悯已与我无分，我竟信了它。”"
  },
  "repent.easy": {
    "en": "\"I wanted the easy way more than the true one.\"",
    "zh": "“我想要容易的路，胜过真实的路。”"
  },
