# Copy to .env and adjust. All vars are prefixed PP_.
PP_ENV=dev
PP_DEBUG=true

# Database (async). In docker-compose the host is "postgres".
PP_DATABASE_URL=postgresql+asyncpg://pilgrim:pilgrim@postgres:5432/pilgrim
PP_DB_POOL_SIZE=10
PP_DB_MAX_OVERFLOW=20
PP_DB_POOL_TIMEOUT=30

# Redis. In docker-compose the host is "redis".
PP_REDIS_URL=redis://redis:6379/0

# Auth — CHANGE THIS in production.
PP_JWT_SECRET=change-me-in-prod
PP_ACCESS_TOKEN_TTL_MIN=1440
PP_REFRESH_TOKEN_TTL_MIN=43200

# CORS — set to your game's domain(s) in production, e.g. https://pilgrim.example.com
PP_CORS_ORIGINS=*

# Rate limit (requests/min/IP)
PP_RATE_LIMIT_PER_MIN=120

# Email verification (bind / recover). Leave SMTP_HOST empty for dev (codes are
# logged, not emailed). In prod, set SMTP_* and turn OFF dev echo.
PP_EMAIL_DEV_ECHO=true
PP_EMAIL_CODE_TTL_SEC=600
PP_EMAIL_CODE_COOLDOWN_SEC=60
PP_SMTP_HOST=
PP_SMTP_PORT=587
PP_SMTP_USER=
PP_SMTP_PASSWORD=
PP_SMTP_FROM=no-reply@pilgrim.example.com
PP_SMTP_TLS=true

# Seasons: empty = quarterly id auto-computed (e.g. 2026-S2); or pin one.
PP_SEASON_OVERRIDE=

# Chat: moderation + retention + images
PP_BANNED_WORDS=badword,辱骂,垃圾广告
PP_BANNED_WORDS_FILE=
PP_CHAT_RETENTION_DAYS=7
PP_CHAT_HISTORY_LIMIT=50
PP_MEDIA_DIR=media
PP_MAX_IMAGE_BYTES=2097152

# Admin access for /admin/* and stats overview — CHANGE THESE in production.
# Static token: used by cron/scripts (X-Admin-Token header).
PP_ADMIN_TOKEN=change-me-admin
# Web login (admin dashboard): username + password -> short-lived admin JWT.
PP_ADMIN_USER=admin
PP_ADMIN_PASSWORD=change-me-admin-pw
PP_ADMIN_SESSION_TTL_MIN=480
# Anti-cheat thresholds
PP_SCORE_TOLERANCE=2
PP_MIN_MS_PER_CHAPTER=3000
PP_DEVOUT_SCORE_MAX=2200
