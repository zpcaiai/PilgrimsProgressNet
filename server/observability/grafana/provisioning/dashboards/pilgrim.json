{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Pilgrim API",
  "tags": ["pilgrim"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests / sec by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pilgrim_http_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s) by path",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pilgrim_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx %)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(pilgrim_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(pilgrim_http_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top endpoints (req/s)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "topk(8, sum(rate(pilgrim_http_requests_total[1m])) by (path))",
          "legendFormat": "{{path}}"
        }
      ]
    }
  ]
}
